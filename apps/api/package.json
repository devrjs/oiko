{
  "name": "oiko-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --env-file=../../.env --watch src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target=bun",
    "start": "bun run dist/server.js",
    "db:push": "drizzle-kit push --force --config drizzle.config.ts",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/swagger": "1.3.1",
    "better-auth": "1.6.12",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.28",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3"
  }
}
